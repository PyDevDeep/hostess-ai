# General Settings
ENVIRONMENT=development

# OpenAI
OPENAI_API_KEY=sk-proj-placeholder
OPENAI_MODEL=gpt-4o-mini-audio-preview
OPENAI_ANALYTICS_MODEL=gpt-4o-mini

# n8n Orchestrator
N8N_WEBHOOK_BASE_URL=http://localhost:5678
FASTAPI_INTERNAL_URL=http://host.docker.internal:8000

# Базова авторизація для веб-інтерфейсу n8n (ОБОВ'ЯЗКОВО замініть на надійні значення)
N8N_BASIC_AUTH_USER=secure_admin_name
N8N_BASIC_AUTH_PASSWORD=SuperSecretPassword123!

# Airtable Database
AIRTABLE_API_KEY=pat_placeholder
AIRTABLE_BASE_ID=app_placeholder

# Telegram Notifications
TELEGRAM_BOT_TOKEN=123456789:ABCdef_placeholder
TELEGRAM_CHAT_ID=-1000000000000

# Application Setup
SENTRY_DSN=
DATABASE_URL=./data/app.db
SESSION_HOLD_TTL_SECONDS=180
LOG_LEVEL=INFO
